{
  "name": "wisp",
  "version": "0.1.0",
  "description": "Wisp — a research-native desktop browser. Rooms, clean search, notes and a concept map, all local-first.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "smoke": "electron-vite build && WISP_SMOKE=1 xvfb-run -a electron . --no-sandbox",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "author": "Shawy404",
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "@ghostery/adblocker-electron": "^2.18.1",
    "@mozilla/readability": "^0.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@types/cytoscape": "^3.21.9",
    "codemirror": "^6.0.2",
    "cytoscape": "^3.34.0",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "private": true
}
